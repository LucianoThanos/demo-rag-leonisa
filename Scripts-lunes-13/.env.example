# ==========================================
# CONFIGURACIÓN DE APIS PARA LLMS
# ==========================================
# Instrucciones: 
# 1. Copia este archivo y renómbralo como .env
# 2. Reemplaza los valores con tus propias API Keys
# ==========================================

# 1. Google Gemini (Consíguela en Google AI Studio)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# 2. OpenAI Oficial
OPENAI_API_KEY=tu_api_key_de_openai_aqui

# 3. DeepSeek Oficial
DEEPSEEK_API_KEY=tu_api_key_de_deepseek_aqui

# 4. Kimi (Moonshot AI)
KIMI_API_KEY=tu_api_key_de_kimi_aqui

# 5. OpenRouter (Alternativa a OpenAI, compatible con sus endpoints)
OPENROUTER_API_KEY=sk-or-v1-tu-clave-super-secreta-aqui

# Nota: Ollama corre local en el puerto 11434, no requiere API Key.
"http://localhost:11434/api/generate"